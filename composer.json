{
  "name": "silverorange/ambiguous-class-name-detector",
  "description": "Command-line tool to check for ambiguous class names with Composer's generated class map.",
  "type": "library",
  "keywords": [
    "composer",
    "classmap",
    "ambiguous"
  ],
  "homepage": "https://github.com/silverorange/ambiguous-class-name-detector",
  "license": "MIT",
  "authors": [
    {
      "name": "Michael Gauthier",
      "email": "mike@silverorange.com"
    }
  ],
  "require": {
    "php": ">=8.0",
    "ext-json": "*",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "3.88.2",
    "phpstan/phpstan": "^2.2",
    "phpunit/phpunit": "^11.5"
  },
  "scripts": {
    "phpcs": "./vendor/bin/php-cs-fixer check -v",
    "phpcs:ci": "./vendor/bin/php-cs-fixer check --config=.php-cs-fixer.php --no-interaction --show-progress=none --diff --using-cache=no -vvv",
    "phpcs:fix": "./vendor/bin/php-cs-fixer fix -v",
    "phpstan": "./vendor/bin/phpstan analyze",
    "phpstan:ci": "./vendor/bin/phpstan analyze -vvv --no-progress --memory-limit 2G",
    "phpstan:baseline": "./vendor/bin/phpstan analyze --generate-baseline",
    "test": "./vendor/bin/phpunit --no-coverage",
    "test:coverage": "rm -rf ./build && XDEBUG_MODE=coverage ./vendor/bin/phpunit && npx serve build/coverage"
  },
  "bin": [
    "bin/check-for-ambiguous-class-names"
  ],
  "autoload": {
    "psr-4": {
      "Silverorange\\AmbiguousClassNameDetector\\": [
        "src/",
        "tests/"
      ]
    }
  }
}
